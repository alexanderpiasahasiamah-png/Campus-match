<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UniMatch Ghana</title>
<link rel="stylesheet" href="style.css">
</head>

<body>

<div class="header">
<h1>UniMatch Ghana</h1>
<p>Find your ideal university in Ghana based on your WASSCE results</p>
</div>

<div class="container">

<h2>Enter Your WASSCE Grades</h2>

<div class="grades-section">
<h3>Core Subjects</h3>
<select id="english"><option value="">English</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<select id="math"><option value="">Mathematics</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<select id="science"><option value="">Integrated Science</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<select id="social"><option value="">Social Studies</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<h3>Electives (Best 3)</h3>
<select id="elective1"><option value="">Elective 1</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<select id="elective2"><option value="">Elective 2</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<select id="elective3"><option value="">Elective 3</option>
<option value="1">A1</option><option value="2">B2</option><option value="3">B3</option><option value="4">C4</option>
<option value="5">C5</option><option value="6">C6</option><option value="7">D7</option><option value="8">E8</option><option value="9">F9</option>
</select>

<button onclick="calculateAggregate()">Check Matches</button>

<div id="result" class="result"></div>

</div>

<script src="script.js"></script>
</body>
</html>
